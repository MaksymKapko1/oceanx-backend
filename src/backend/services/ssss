def format_lot_size(size: float, lot_size: float) -> float:
    if lot_size <= 0:
        return size

    # 1. Считаем, сколько целых "шагов" помещается в наш размер
    # 0.000719 / 0.00001 = 71.9 -> math.floor отрубает .9 -> получаем 71
    steps = math.floor(size / lot_size)

    # 2. Умножаем количество шагов обратно на размер шага
    # 71 * 0.00001 = 0.00071
    formatted_size = steps * lot_size

    # 3. Фиксим баги плавающей запятой в Питоне (иногда умножение дает 0.00071000000001)
    return round(formatted_size, 8)
class CopyTradeExecutor:
    def __init__(self, db_pool):
        self.db_pool = db_pool
        self.subscription_locks = {}
        self.rate_limit = asyncio.Semaphore(20) #TODO Пересмотреть

        self.balances_cache = {}

        encryption_key = os.getenv("MASTER_KEY")
        if encryption_key:
            self.fernet = Fernet(encryption_key.encode())
        else:
            logger.error("КРИТИЧЕСКИ: ENCRYPTION_KEY не найден в .env!")

    async def start_background_tasks(self):
        asyncio.create_task(self._sync_balances_loop())

    async def _log_copied_trade(self, sub_id, order_id, symbol, side, size, price, master_size):
        query = """
            INSERT INTO copied_trades
            (subscription_id, follower_trade_id, symbol, side, size, entry_price, status, master_size)
            VALUES ($1, $2, $3, $4, $5, $6, 'open', $7)
        """
        try:
            async with self.db_pool.acquire() as conn:
                await conn.execute(query, sub_id, order_id, symbol, side, size, price, master_size)
        except Exception as e:
            logger.error(f"❌ Не удалось записать сделку в лог: {e}")

    async def _sync_balances_loop(self):
        logger.info("🔄 Фоновая синхронизация балансов запущена...")
        while True:
            try:
                async with self.db_pool.acquire() as conn:
                    users = await conn.fetch("""
                                SELECT DISTINCT u.wallet_address
                                FROM subscriptions s
                                JOIN users u ON s.user_id = u.id
                                WHERE s.is_active = TRUE
                            """)

                for row in users:
                    wallet = row['wallet_address']
                    real_balance = await pacifica_client.fetch_user_balance(wallet)
                    self.balances_cache[wallet] = real_balance

                    await asyncio.sleep(2)

            except Exception as e:
                logger.error(f"❌ Ошибка в цикле синхронизации балансов: {e}")

            await asyncio.sleep(40)

    def _decrypt_key(self, encrypted_key: str) -> str:
        return self.fernet.decrypt(encrypted_key.encode()).decode()

    async def process_master_signal(self, master_wallet: str, symbol: str, side: str,
                                    master_price: float, master_amount: float):
        logger.info(f"⚙️ EXECUTOR: Запуск копирования для мастера {master_wallet} ({side} {symbol} @ {master_price})")
        query = """
                    SELECT
                        s.id AS subscription_id,
                        s.is_reverse,
                        u.wallet_address AS user_wallet,
                        r.margin_allocation_pct,
                        r.max_total_exposure_usd,
                        r.max_leverage,
                        r.max_slippage,
                        r.allowed_markets,
                        a.public_key AS agent_pub,
                        a.encrypted_private_key AS agent_priv
                    FROM subscriptions s
                    JOIN users u ON s.user_id = u.id
                    JOIN user_risk_settings r ON s.user_id = r.user_id
                    JOIN agent_wallets a ON s.user_id = a.user_id
                    WHERE s.master_wallet = $1
                      AND s.is_active = TRUE
                      AND a.is_active = TRUE;
        """
        try:
            async with self.db_pool.acquire() as conn:
                followers = await conn.fetch(query, master_wallet)
        except Exception as e:
            logger.error(f"❌ Ошибка выгрузки подписчиков: {e}")
            return
        if not followers:
            logger.info(f"ℹ️ У мастера {master_wallet} пока нет активных подписчиков с настройками.")
            return

        tasks = []

        for follower in followers:
            sub_id = follower['subscription_id']
            if sub_id not in self.subscription_locks:
                self.subscription_locks[sub_id] = asyncio.Lock()
            tasks.append(self._execute_with_lock(sub_id, follower, symbol, side, master_price, master_amount))
            # tasks.append(
            #     self.execute_user_order(follower, symbol, side, master_price, master_amount)
            # )
        await asyncio.gather(*tasks)

    async def _execute_with_lock(self, sub_id, *args):
        async with self.subscription_locks[sub_id]:  # 👈 Только один сигнал в один момент времени
            await self.execute_user_order(*args)

    async def execute_user_order(self, follower: dict, symbol: str, side: str, price: float, master_amount: float):
        async with self.rate_limit:

            if follower.get('is_reverse'):
                reverse_map = {
                    "open_long": "open_short",
                    "open_short": "open_long",
                    "close_long": "close_short",
                    "close_short": "close_long"
                }
                side = reverse_map.get(side, side)
                logger.info(f"🔄 РЕВЕРС РЕЖИМ: Оригинальная сделка перевернута на {side}")


            wallet = follower['user_wallet']
            sub_id = follower['subscription_id']
            is_reduce_only = side.startswith("close")

            trade_record_ids = None
            margin = 0.0
            close_ratio = 1.0

            try:
                market_info = pacifica_client.cache.get('market_info', {}).get(symbol)
                if not market_info: return

                allowed_markets = follower.get('allowed_markets')

                if allowed_markets and len(allowed_markets) > 0:
                    if symbol not in allowed_markets:
                        if not is_reduce_only:
                            logger.info(f"🚫 Копирование {symbol} отклонено: монеты нет в белом списке для {wallet[:6]}")
                            return

                if not is_reduce_only:
                    query_exposure = """
                                        SELECT COALESCE(SUM(size * entry_price), 0) as current_exposure
                                        FROM copied_trades ct
                                        JOIN subscriptions s ON ct.subscription_id = s.id
                                        WHERE s.user_id = (SELECT user_id FROM subscriptions WHERE id = $1)
                                          AND ct.status = 'open'
                                    """
                    exposure_data = await self.db_pool.fetchrow(query_exposure, sub_id)
                    current_exposure = float(exposure_data['current_exposure'])

                    # Достаем лимит из конфига (нужно добавить в SELECT в process_master_signal)
                    max_limit = float(follower.get('max_total_exposure_usd', 500))

                    if current_exposure >= max_limit:
                        logger.warning(
                            f"🚫 ЛИМИТ ПРЕВЫШЕН: Текущая поза ${current_exposure:.2f} >= Лимита ${max_limit:.2f}. Пропуск.")
                        return

                    # (Опционально) Если новая сделка выведет нас за лимит, можем либо обрезать её, либо скипнуть
                    # Но пока давай просто проверять "вход разрешен/запрещен"

                if is_reduce_only:
                    # --- 1. ЛОГИКА ЗАКРЫТИЯ (СНЕЖНЫЙ КОМ) ---
                    query_agg = """
                        SELECT array_agg(id) as ids,
                               COALESCE(SUM(size), 0) as total_f_size,
                               COALESCE(SUM(master_size), 0) as total_m_size
                        FROM copied_trades
                        WHERE subscription_id = $1 AND symbol = $2 AND status = 'open'
                    """
                    agg_data = await self.db_pool.fetchrow(query_agg, sub_id, symbol)

                    if not agg_data or not agg_data['ids']:
                        logger.warning(f"⚠️ Нет открытых сделок по {symbol} для {wallet[:6]}")
                        return

                    trade_record_ids = agg_data['ids']
                    total_f_size = float(agg_data['total_f_size'])
                    total_m_size = float(agg_data['total_m_size'])

                    if total_m_size > 0:
                        close_ratio = min(master_amount / total_m_size, 1.0)

                    raw_amount = total_f_size * close_ratio



                else:

                    # --- 1. ПРОВЕРКА ТЕКУЩЕГО EXPOSURE ---

                    query_exposure = """

                                        SELECT COALESCE(SUM(size * entry_price), 0) as current_exposure

                                        FROM copied_trades ct

                                        JOIN subscriptions s ON ct.subscription_id = s.id

                                        WHERE s.user_id = (SELECT user_id FROM subscriptions WHERE id = $1)

                                          AND ct.status = 'open'

                                    """

                    exposure_data = await self.db_pool.fetchrow(query_exposure, sub_id)

                    current_exposure = float(exposure_data['current_exposure'])

                    max_limit = float(follower.get('max_total_exposure_usd', 500))

                    # --- 2. РАСЧЕТ ОБЪЕМА (КАК РАНЬШЕ) ---

                    query_check = "SELECT COALESCE(SUM(size), 0) as f_total, COALESCE(SUM(master_size), 0) as m_total FROM copied_trades WHERE subscription_id = $1 AND symbol = $2 AND status = 'open'"

                    pos_info = await self.db_pool.fetchrow(query_check, sub_id, symbol)

                    f_total, m_total = float(pos_info['f_total']), float(pos_info['m_total'])

                    safe_leverage = min(follower['max_leverage'], market_info['max_leverage'])

                    if m_total > 0:

                        add_ratio = master_amount / m_total

                        raw_amount = f_total * add_ratio

                    else:

                        if wallet not in self.balances_cache:
                            self.balances_cache[wallet] = await pacifica_client.fetch_user_balance(wallet)

                        user_balance = self.balances_cache.get(wallet, 0.0)

                        margin = user_balance * (follower['margin_allocation_pct'] / 100)

                        raw_amount = (margin * safe_leverage) / price

                    # --- 3. ЖЕСТКАЯ ПРОВЕРКА И ОБРЕЗКА (CAP) ---

                    new_trade_value = raw_amount * price

                    if current_exposure + new_trade_value > max_limit:

                        available_quota = max_limit - current_exposure

                        if available_quota <= 0:
                            logger.warning(f"🚫 ЛИМИТ ИСЧЕРПАН ({current_exposure:.2f}$ >= {max_limit:.2f}$). Скип.")

                            return

                        # Обрезаем объем сделки до остатка лимита

                        raw_amount = available_quota / price

                        logger.info(
                            f"✂️ ОБРЕЗКА ПО ЛИМИТУ: Сделка уменьшена до ${available_quota:.2f}, чтобы вписаться в лимит ${max_limit:.2f}")

                    # Считаем финальную маржу для кэша

                    margin = (raw_amount * price) / safe_leverage

                    self.balances_cache[wallet] -= margin

                # --- 3. ПРОВЕРКА ЛОТА ---
                lot_size = market_info['lot_size']

                if is_reduce_only:
                    # 🔥 ТРЮК: Если мы закрываемся (особенно на 99%+),
                    # округляем ВВЕРХ (ceil). Reduce-only обрежет лишнее, и пыли не останется.
                    steps = math.ceil(raw_amount / lot_size)
                else:
                    # При открытии всегда округляем ВНИЗ (floor), чтобы не выйти за рамки баланса
                    steps = math.floor(raw_amount / lot_size)

                formatted_size = round(steps * lot_size, 8)

                if formatted_size <= 0:
                    logger.warning(f"⚠️ Лот слишком мал ({formatted_size}).")
                    # 🔥 ЕСЛИ ЛОТ МАЛ — ВОЗВРАЩАЕМ МАРЖУ В КЭШ ПЕРЕД ВЫХОДОМ
                    if not is_reduce_only and margin > 0:
                        self.balances_cache[wallet] += margin
                    return

                amount_str = f"{formatted_size:f}".rstrip('0').rstrip('.')

                # (Блок подготовки подписи и ws_message остается прежним...)
                agent_priv_str = self._decrypt_key(follower['agent_priv'])
                keypair = Keypair.from_base58_string(agent_priv_str)
                timestamp = int(time.time() * 1_000)
                client_order_id = str(uuid.uuid4())
                side_mapping = {"open_long": "bid", "close_long": "ask", "open_short": "ask", "close_short": "bid"}
                api_side = side_mapping.get(side, "bid")

                signature_payload = {
                    "symbol": symbol, "reduce_only": is_reduce_only, "amount": amount_str,
                    "side": api_side, "slippage_percent": str(follower['max_slippage']),
                    "client_order_id": client_order_id
                }
                _, signature = sign_message(
                    {"timestamp": timestamp, "expiry_window": 5000, "type": "create_market_order"}, signature_payload,
                    keypair)

                ws_message = {
                    "id": str(uuid.uuid4()),
                    "params": {"create_market_order": {
                        "account": wallet, "agent_wallet": follower['agent_pub'],
                        "signature": signature, "timestamp": timestamp, "expiry_window": 5000,
                        **signature_payload
                    }},
                }

                # --- 4. ОТПРАВКА И ОБРАБОТКА ---
                async with websockets.connect(WS_URL) as websocket:
                    await websocket.send(json.dumps(ws_message))
                    raw_res = await websocket.recv()
                    response = json.loads(raw_res)

                    if response.get("code") == 200:
                        logger.info(f"✅ УСПЕХ: {wallet[:6]} {side}")
                        if is_reduce_only:
                            if close_ratio >= 0.99:
                                # Закрываем всю пачку ордеров
                                await self.db_pool.execute(
                                    "UPDATE copied_trades SET status = 'closed' WHERE id = ANY($1)", trade_record_ids)
                            else:
                                # Пропорционально уменьшаем всю пачку
                                remain = 1.0 - close_ratio
                                await self.db_pool.execute(
                                    "UPDATE copied_trades SET size = size * $1, master_size = master_size * $1 WHERE id = ANY($2)",
                                    remain, trade_record_ids
                                )
                        else:
                            await self._log_copied_trade(sub_id, client_order_id, symbol, api_side, formatted_size,
                                                         price, master_amount)
                    else:
                        err_msg = response.get('err', '')
                        logger.error(f"❌ ОШИБКА БИРЖИ: {err_msg}")
                        # 🔥 ВОЗВРАЩАЕМ МАРЖУ ПРИ ОТКАЗЕ БИРЖИ
                        if not is_reduce_only and margin > 0:
                            self.balances_cache[wallet] += margin
                        # Самовосстановление БД при ошибке 420
                        if is_reduce_only and trade_record_ids and (
                                response.get("code") == 420 or "No position" in err_msg):
                            await self.db_pool.execute("UPDATE copied_trades SET status = 'closed' WHERE id = ANY($1)",
                                                       trade_record_ids)

            except Exception as e:
                logger.error(f"❌ КРИТИЧЕСКАЯ ОШИБКА: {e}")
                # 🔥 ЕСЛИ ВСЁ РУХНУЛО (ошибка кода/сети) — ВОЗВРАЩАЕМ МАРЖУ
                if not is_reduce_only and margin > 0:
                    self.balances_cache[wallet] += margin


import logging
import asyncpg

logger = logging.getLogger(__name__)

async def init_db(pool: asyncpg.Pool):
    query_create_liqs_table = """
    CREATE TABLE IF NOT EXISTS liqs (
        trade_id BIGINT PRIMARY KEY,
        coin VARCHAR(50) NOT NULL,
        price DOUBLE PRECISION NOT NULL,
        size DOUBLE PRECISION NOT NULL,
        usd_amount DOUBLE PRECISION NOT NULL,
        side VARCHAR(30) NOT NULL,
        liq_type VARCHAR(50) NOT NULL,
        timestamp BIGINT NOT NULL,
        nonce BIGINT
    );
    """

    query_create_volume_table = """
    CREATE TABLE IF NOT EXISTS volume (
        timestamp BIGINT PRIMARY KEY,
        usd_volume DOUBLE PRECISION NOT NULL
    );
    """

    query_create_user_table = """
    CREATE TABLE IF NOT EXISTS users (
        id SERIAL PRIMARY KEY,
        wallet_address VARCHAR(256) UNIQUE NOT NULL,
        pacifica_api_key VARCHAR(256),
        created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
    );
    """

    query_create_subscriptions_table = """
       CREATE TABLE IF NOT EXISTS subscriptions (
           id SERIAL PRIMARY KEY,
           user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE,
           master_wallet VARCHAR(255) NOT NULL,
           is_active BOOLEAN DEFAULT TRUE,
           is_reverse BOOLEAN DEFAULT FALSE,
           copy_amount NUMERIC(10, 2),
           max_leverage INTEGER DEFAULT 10,
           created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
           updated_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,

           UNIQUE (user_id, master_wallet)
       );
       """

    query_create_copied_trades_table = """
       CREATE TABLE IF NOT EXISTS copied_trades (
            id SERIAL PRIMARY KEY,
            subscription_id INTEGER NOT NULL REFERENCES subscriptions(id) ON DELETE CASCADE,
            master_trade_id VARCHAR(255),
            master_size NUMERIC(18, 6) DEFAULT 0,
            follower_trade_id VARCHAR(255),
            symbol VARCHAR(50) NOT NULL,
            side VARCHAR(20) NOT NULL,
            entry_price NUMERIC(18, 6),
            size NUMERIC(18, 6),
            status VARCHAR(50) DEFAULT 'open', -- open, closed, failed
            error_log TEXT,
            created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP
       );
       """

    query_create_agent_wallets_table = """
            CREATE TABLE IF NOT EXISTS agent_wallets (
                id SERIAL PRIMARY KEY,
                user_id INTEGER NOT NULL REFERENCES users(id) ON DELETE CASCADE,
                public_key VARCHAR(256) NOT NULL,
                encrypted_private_key TEXT NOT NULL,
                is_active BOOLEAN DEFAULT TRUE,
                created_at TIMESTAMP WITH TIME ZONE DEFAULT CURRENT_TIMESTAMP,
                CONSTRAINT unique_active_agent UNIQUE (user_id)
            );
        """

    query_create_user_risk_settings_table = """
        CREATE TABLE IF NOT EXISTS user_risk_settings (
        id SERIAL PRIMARY KEY,
        user_id INTEGER UNIQUE NOT NULL REFERENCES users(id) ON DELETE CASCADE,
        margin_allocation_pct INTEGER NOT NULL,
        max_leverage INTEGER NOT NULL,
        max_slippage NUMERIC(5, 2) NOT NULL,
        max_total_exposure_usd NUMERIC(18, 2) DEFAULT 500.00,
        allowed_markets VARCHAR(20)[] DEFAULT '{}',
        updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
    );
    """

    queries_indexes = [
        "CREATE INDEX IF NOT EXISTS idx_liqs_timestamp ON liqs (timestamp DESC);",
        "CREATE INDEX IF NOT EXISTS idx_liqs_coin ON liqs (coin);",
        "CREATE INDEX IF NOT EXISTS idx_liqs_usd_amount ON liqs (usd_amount DESC);",
        "CREATE INDEX IF NOT EXISTS idx_users_wallet ON users(wallet_address);",
        "CREATE INDEX IF NOT EXISTS idx_subs_user_master ON subscriptions(user_id, master_wallet);",
        "CREATE INDEX IF NOT EXISTS idx_copied_trades_sub ON copied_trades(subscription_id);",
        "CREATE INDEX IF NOT EXISTS idx_agent_wallets_user_id ON agent_wallets(user_id);"
    ]

    try:
        async with pool.acquire() as conn:
            await conn.execute(query_create_liqs_table)
            await conn.execute(query_create_volume_table)
            await conn.execute(query_create_user_table)
            await conn.execute(query_create_subscriptions_table)
            await conn.execute(query_create_copied_trades_table)
            await conn.execute(query_create_agent_wallets_table)
            await conn.execute(query_create_user_risk_settings_table)

            for q_idx in queries_indexes:
                await conn.execute(q_idx)

        logger.info("✅ База данных (liqs, volume, users, subs, copied_trades, agents, risk table) и индексы успешно инициализированы")
    except Exception as e:
        logger.error(f"❌ Критическая ошибка при инициализации БД: {e}")